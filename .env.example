# BrainTwinCDK environment — copy to `.env` and fill in real values.
# `.env` is git-ignored; `.env.example` is committed as documentation.
#
# Load before running cdk, e.g.:
#   set -a && source .env && set +a
#   npx cdk synth

# Email that AWS Budgets notifies when a spend threshold trips.
# Operator PII — kept out of source so it never lands in git history.
# Leave unset for `cdk synth` / tests; required before `cdk deploy`.
BRAINTWIN_ALERT_EMAIL=
