            "Value": "BrainTwin",
          },
          {
            "Key": "PublicBrand",
            "Value": "DigitalTwin",
          },
          {
            "Key": "Region",
            "Value": "us-west-2",
          },
        ],
      },
      "Type": "AWS::IAM::Role",
    },
    "ObservabilityEbsSnapshotPolicyC49EC1D0": {
      "Properties": {
        "Description": "BrainTwin-EBS Daily Snapshots",
        "ExecutionRoleArn": {
          "Fn::GetAtt": [
            "ObservabilityDlmRoleC8FECA3D",
            "Arn",
          ],
        },
        "PolicyDetails": {
          "PolicyType": "EBS_SNAPSHOT_MANAGEMENT",
          "ResourceTypes": [
            "VOLUME",
          ],
          "Schedules": [
            {
              "CopyTags": true,
              "CreateRule": {
                "Interval": 24,
                "IntervalUnit": "HOURS",
                "Times": [
                  "03:00",
                ],
              },
              "Name": "Daily",
              "RetainRule": {
                "Count": 7,
              },
              "TagsToAdd": [
                {
                  "Key": "Name",
                  "Value": "BrainTwin-EBS-Snapshot",
                },
                {
                  "Key": "Source",
                  "Value": "DLM",
                },
              ],
            },
          ],
          "TargetTags": [
            {
              "Key": "Project",
              "Value": "BrainTwin",
            },
          ],
        },
        "State": "ENABLED",
        "Tags": [
          {
            "Key": "ManagedBy",
            "Value": "BrainTwinCDK",
          },
          {
            "Key": "Phase",
            "Value": "4.0.6",
          },
          {
            "Key": "Project",
            "Value": "BrainTwin",
          },
          {
            "Key": "PublicBrand",
            "Value": "DigitalTwin",
          },
          {
            "Key": "Region",
            "Value": "us-west-2",
          },
        ],
      },
      "Type": "AWS::DLM::LifecyclePolicy",
    },
    "StorageAppRepo7969A3A5": {
      "DeletionPolicy": "Delete",
      "Properties": {
        "EmptyOnDelete": true,
        "ImageScanningConfiguration": {
          "ScanOnPush": true,
        },
        "ImageTagMutability": "IMMUTABLE",
        "LifecyclePolicy": {
          "LifecyclePolicyText": "{"rules":[{"rulePriority":1,"description":"Keep last 5 untagged images (orphan manifests)","selection":{"tagStatus":"untagged","countType":"imageCountMoreThan","countNumber":5},"action":{"type":"expire"}},{"rulePriority":2,"description":"Keep last 30 tagged images (~3 months at weekly cadence)","selection":{"tagStatus":"any","countType":"imageCountMoreThan","countNumber":30},"action":{"type":"expire"}}]}",
        },
        "RepositoryName": "braintwin/app",
        "Tags": [
          {
            "Key": "ManagedBy",
            "Value": "BrainTwinCDK",
          },
          {
            "Key": "Phase",
            "Value": "4.0.6",
          },
          {
            "Key": "Project",
            "Value": "BrainTwin",
          },
          {
            "Key": "PublicBrand",
            "Value": "DigitalTwin",
          },
          {
            "Key": "Region",
            "Value": "us-west-2",
          },
        ],
      },
      "Type": "AWS::ECR::Repository",
      "UpdateReplacePolicy": "Delete",
    },
    "StorageStateBucket934B7EF1": {
      "DeletionPolicy": "Retain",
      "Properties": {
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "AES256",
              },
            },
          ],
        },
        "BucketName": "braintwin-state-123456789012-us-west-2",
        "LifecycleConfiguration": {
          "Rules": [
            {
              "AbortIncompleteMultipartUpload": {
                "DaysAfterInitiation": 1,
              },
              "ExpirationInDays": 7,
              "Id": "litestream-wal-expire-7d",
              "NoncurrentVersionExpiration": {
                "NoncurrentDays": 7,
              },
              "Prefix": "litestream/",
              "Status": "Enabled",
            },
            {
              "AbortIncompleteMultipartUpload": {
                "DaysAfterInitiation": 1,
              },
              "ExpirationInDays": 30,
              "Id": "chroma-nightly-expire-30d",
              "NoncurrentVersionExpiration": {
                "NoncurrentDays": 7,
              },
              "Prefix": "chroma-nightly/",
              "Status": "Enabled",
            },
            {
              "AbortIncompleteMultipartUpload": {
                "DaysAfterInitiation": 1,
              },
              "Id": "images-transition-ia-30d",
              "NoncurrentVersionExpiration": {
                "NoncurrentDays": 30,
              },
              "Prefix": "images/",
              "Status": "Enabled",
              "Transitions": [
                {
                  "StorageClass": "STANDARD_IA",
                  "TransitionInDays": 30,
                },
              ],
            },
          ],
        },
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": true,
          "BlockPublicPolicy": true,
          "IgnorePublicAcls": true,
          "RestrictPublicBuckets": true,
        },
        "Tags": [
          {
            "Key": "ManagedBy",
            "Value": "BrainTwinCDK",
          },
          {
            "Key": "Phase",
            "Value": "4.0.6",
          },
          {
            "Key": "Project",
            "Value": "BrainTwin",
          },
          {
            "Key": "PublicBrand",
            "Value": "DigitalTwin",
          },
          {
            "Key": "Region",
            "Value": "us-west-2",
          },
        ],
        "VersioningConfiguration": {
          "Status": "Enabled",
        },
      },
      "Type": "AWS::S3::Bucket",
      "UpdateReplacePolicy": "Retain",
    },
    "StorageStateBucketPolicy27964DEE": {
      "Properties": {
        "Bucket": {
          "Ref": "StorageStateBucket934B7EF1",
        },
        "PolicyDocument": {
          "Statement": [
            {
              "Action": "s3:*",
              "Condition": {
                "Bool": {
                  "aws:SecureTransport": "false",
                },
              },
              "Effect": "Deny",
              "Principal": {
                "AWS": "*",
              },
              "Resource": [
                {
                  "Fn::GetAtt": [
                    "StorageStateBucket934B7EF1",
                    "Arn",
                  ],
                },
                {
                  "Fn::Join": [
                    "",
                    [
                      {
                        "Fn::GetAtt": [
                          "StorageStateBucket934B7EF1",
                          "Arn",
                        ],
                      },
                      "/*",
                    ],
                  ],
                },
              ],
            },
          ],
          "Version": "2012-10-17",
        },
      },
      "Type": "AWS::S3::BucketPolicy",
    },
  },
  "Rules": {
    "CheckBootstrapVersion": {
      "Assertions": [
        {
          "Assert": {
            "Fn::Not": [
              {
                "Fn::Contains": [
                  [
                    "1",
                    "2",
                    "3",
                    "4",
                    "5",
                  ],
                  {
                    "Ref": "BootstrapVersion",
                  },
                ],
              },
            ],
          },
          "AssertDescription": "CDK bootstrap stack version 6 required. Please run 'cdk bootstrap' with a recent version of the CDK CLI.",
        },
      ],
    },
  },
}
`;
