    "ObservabilityDlmRoleC8FECA3D": {
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Statement": [
            {
              "Action": "sts:AssumeRole",
              "Effect": "Allow",
              "Principal": {
                "Service": "dlm.amazonaws.com",
              },
            },
          ],
          "Version": "2012-10-17",
        },
        "Description": "Lets DLM call EC2 to create/delete EBS snapshots.",
        "ManagedPolicyArns": [
          {
            "Fn::Join": [
              "",
              [
                "arn:",
                {
                  "Ref": "AWS::Partition",
                },
                ":iam::aws:policy/service-role/AWSDataLifecycleManagerServiceRole",
              ],
            ],
          },
        ],
        "RoleName": "BrainTwin-DLM-Role",
        "Tags": [
          {
            "Key": "ManagedBy",
            "Value": "BrainTwinCDK",
          },
          {
            "Key": "Phase",
            "Value": "4.0.6",
          },
          {
